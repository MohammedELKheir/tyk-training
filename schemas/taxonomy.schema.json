{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Taxonomy registry",
  "type": "object",
  "required": ["topics", "categories", "audiences", "use_cases"],
  "properties": {
    "topics": { "$ref": "#/$defs/taxonomyDimension" },
    "categories": { "$ref": "#/$defs/taxonomyDimension" },
    "audiences": { "$ref": "#/$defs/taxonomyDimension" },
    "use_cases": { "$ref": "#/$defs/taxonomyDimension" },
    "products": { "$ref": "#/$defs/taxonomyDimension" }
  },
  "additionalProperties": false,
  "$defs": {
    "taxonomyDimension": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "additionalProperties": {
        "type": "object",
        "required": ["label"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  }
}
